{
	"name": "blog",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp"
		]
	},
	"scripts": {
		"dev": "vite dev",
		"new": "node scripts/new-post.js",
		"build": "cross-env ADAPTER=static vite build && node scripts/post-images.js",
		"build:cloudflare": "cross-env ADAPTER=cloudflare vite build && cross-env OUTPUT_DIR=.svelte-kit/cloudflare node scripts/post-images.js",
		"build:cf-pages": "cross-env ADAPTER=static vite build && node scripts/post-images.js",
		"build:netlify": "cross-env ADAPTER=static vite build && node scripts/post-images.js",
		"build:vercel": "cross-env ADAPTER=static vite build && node scripts/post-images.js",
		"build:edgeone": "cross-env ADAPTER=static vite build && node scripts/post-images.js",
		"preview": "vite preview",
		"deploy:cloudflare": "pnpm build:cloudflare && wrangler deploy",
		"deploy:cf-pages": "pnpm build:cf-pages && wrangler pages deploy build",
		"deploy:netlify": "pnpm build:netlify && netlify deploy --prod --dir=build",
		"deploy:vercel": "pnpm build:vercel && vercel --prod",
		"deploy:edgeone": "pnpm build:edgeone && edgeone pages deploy build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify-json/simple-icons": "^1.2.85",
		"@iconify/svelte": "^5.2.1",
		"@motionone/dom": "^10.18.0",
		"@shikijs/transformers": "^4.2.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"katex": "^0.17.0",
		"mdsvex": "^0.12.7",
		"photoswipe": "^5.4.4",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"sharp": "^0.34.5",
		"shiki": "^4.2.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"wrangler": "^4.98.0"
	}
}
